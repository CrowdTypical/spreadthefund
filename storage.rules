rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Group images stored as group_images/{groupId}/{uid}.jpg
    // Read: authenticated users only. Download URLs include a token that acts
    // as the primary access control — only group members receive the URL via
    // Firestore, which is restricted by membership rules.
    // Write: only the user whose UID matches the filename.
    match /group_images/{groupId}/{uid}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
